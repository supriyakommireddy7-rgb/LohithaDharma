# Server configurations
PORT=5001
NODE_ENV=development

# Database connection
MONGO_URI=mongodb://localhost:27017/lohitha_dharma

# LLM Providers (Configure at least one to enable AI replies)
# 1. Gemini API Key (Recommended, free tier available)
GEMINI_API_KEY=your_gemini_api_key_here

# 2. OpenAI API Key (Alternative)
OPENAI_API_KEY=your_openai_api_key_here

# Nodemailer / Gmail SMTP Configurations
# (Optional. If blank, system runs in simulation mode log)
SMTP_USER=your_gmail_address@gmail.com
# Admin Auth Configuration
ADMIN_EMAILS=admin1@gmail.com,admin2@gmail.com
# Use Google App Password (not your primary password)
# See: https://support.google.com/accounts/answer/185833
SMTP_PASS=xxxx_xxxx_xxxx_xxxx
